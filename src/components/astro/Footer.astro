---
import { Image } from "astro:assets";
import RuriImage from "src/img/sprites/ruri_transparent.png";

const siteLinks = [
  { label: "Projects", href: "/projects" },
  { label: "Blog", href: "/blog" },
  { label: "Reviews", href: "/reviews" },
  { label: "About", href: "/about" },
];

const elsewhere = [
  { label: "github ↗", href: "https://github.com/BarneyLaw" },
  { label: "linkedin ↗", href: "https://www.linkedin.com/in/leifsenlaw/" },
];

---

<footer class="bg-secondary border-t border-border">
  <div class="max-w-5xl mx-auto px-6 py-8">
    <div class="grid grid-cols-4 gap-6">
      <div>
        <a href="/" class="flex items-center gap-2.5 hover:opacity-80 transition-opacity">
          <div
            class="w-7 h-7 rounded-md text-[11px] bg-primary flex items-center justify-center font-bold font-mono text-white flex-shrink-0"
          >
            &gt;_
          </div>
          <div class="flex flex-col leading-[1.05]">
            <span class="font-bold font-mono text-foreground text-[13px]">packetcraft</span>
            <span class="font-mono text-muted-foreground text-[9px]">.dev</span>
          </div>
        </a>
        <p class="text-[11px] font-mono text-muted-foreground mt-3 leading-[1.6]">
          tinkerer documenting homelab builds, networking experiments, and gaming-adjacent projects.
        </p>
      </div>
      <div>
        <div class="text-[9px] font-mono text-muted-foreground mb-3">/site</div>
        <div class="flex flex-col gap-1.5">
          {
            siteLinks.map((l) => (
              <a
                href={l.href}
                class="text-[11px] font-mono text-foreground/60 hover:text-foreground cursor-pointer transition-colors"
              >
                {l.label}
              </a>
            ))
          }
        </div>
      </div>
      <div>
        <div class="text-[9px] font-mono text-muted-foreground mb-3">/elsewhere</div>
        <div class="flex flex-col gap-1.5">
          {
            elsewhere.map((link) => (
              <a
                href={link.href}
                class="text-[11px] font-mono text-foreground/60 hover:text-foreground transition-colors"
                target={link.href.startsWith("http") ? "_blank" : undefined}
                rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
      <div
        class="flex items-center justify-center p-3 text-center"
      >
        <Image 
          src={RuriImage}
          alt="Ruri" 
          width={200} 
          height={150} 
        />
      </div>
    </div>
    <div class="mt-6 pt-4 border-t border-border flex justify-between">
      <span class="text-[10px] font-mono text-muted-foreground">
        © 2026 packetcraft · served by k3s @ home
      </span>
      <span class="text-[10px] font-mono text-muted-foreground">
        uptime 99.4% · build #1284
      </span>
    </div>
  </div>
</footer>
