---
import Layout from "../layouts/Layout.astro";
import Hatch from "../components/astro/Hatch.astro";
import { getBlogPosts } from "../lib/content";

const posts = await getBlogPosts();
const featured = posts.find((p) => p.data.featured) ?? posts[0];
const rest = posts.filter((p) => p.id !== featured?.id);
---

<Layout title="blog · packetcraft">
  <main class="max-w-5xl mx-auto px-6 py-12">
    <h1 class="font-bold font-mono text-3xl text-foreground mb-3">blog</h1>
    <p class="text-[12px] font-mono text-muted-foreground mb-8">
      homelab notes · networking deep-dives · gaming-adjacent things
    </p>

    {/* Featured */}
    {
      featured && (
        <a
          href={`/blog/${featured.id}`}
          class="block bg-card border border-border rounded overflow-hidden mb-8 hover:border-primary/50 transition-colors cursor-pointer group"
        >
          <Hatch class="h-32 w-full" label="featured cover" />
          <div class="p-5">
            <div class="flex gap-2 items-center mb-3">
              <span class="text-[9px] font-mono text-primary border border-primary rounded px-1.5 py-0.5">
                FEATURED
              </span>
              <span class="text-[9px] font-mono text-muted-foreground">
                {featured.data.date} · {featured.data.readTime} · {featured.data.category}
              </span>
            </div>
            <div class="font-bold font-mono text-[16px] text-foreground group-hover:text-primary transition-colors leading-snug mb-2">
              {featured.data.title}
            </div>
            <div class="text-[12px] font-mono text-muted-foreground leading-relaxed">
              {featured.data.excerpt}
            </div>
          </div>
        </a>
      )
    }

    {/* List */}
    <div class="flex flex-col divide-y divide-border">
      {
        rest.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="block py-5 hover:bg-primary/5 -mx-2 px-2 rounded transition-colors cursor-pointer group"
          >
            <div class="text-[9px] font-mono text-muted-foreground mb-2">
              {post.data.date} · {post.data.readTime} · {post.data.category}
            </div>
            <div class="font-bold font-mono text-[13px] text-foreground group-hover:text-primary transition-colors mb-1.5">
              {post.data.title}
            </div>
            <div class="text-[11px] font-mono text-muted-foreground leading-relaxed">
              {post.data.excerpt}
            </div>
          </a>
        ))
      }
    </div>

    {/* Pagination */}
    <div class="flex justify-center gap-2 mt-8">
      {
        [1, 2, 3].map((n) => (
          <button
            class:list={[
              "w-8 h-8 text-[10px] font-mono rounded cursor-pointer transition-colors",
              n === 1
                ? "bg-primary text-white"
                : "border border-border text-muted-foreground hover:border-primary/40",
            ]}
          >
            {n}
          </button>
        ))
      }
    </div>
  </main>
</Layout>
