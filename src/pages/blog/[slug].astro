---
import { render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { getBlogPosts } from "../../lib/content";

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} · packetcraft`} description={post.data.excerpt}>
  <main class="max-w-5xl mx-auto px-6 py-12">
    <a
      href="/blog"
      class="inline-block text-[10px] font-mono text-muted-foreground hover:text-foreground transition-colors mb-5 cursor-pointer"
    >
      ← blog
    </a>

    <div class="text-[9px] font-mono text-muted-foreground mb-2">
      {post.data.date} · {post.data.readTime} · {post.data.category}
    </div>
    <h1 class="font-bold font-mono text-2xl text-foreground leading-snug mb-6">
      {post.data.title}
    </h1>

    <article class="mdx-content">
      <Content />
    </article>

    {/* gap: view counts + comments (Go backend via src/lib/api.ts) go here */}
  </main>
</Layout>
