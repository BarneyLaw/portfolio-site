---
import Layout from "../../layouts/Layout.astro";
import StatusBadge from "../../components/astro/StatusBadge.astro";
import Hatch from "../../components/astro/Hatch.astro";
import { projects } from "../../data/projects";

const filters = [
  { label: "all", id: "all" },
  { label: "shipped", id: "SHIPPED" },
  { label: "in progress", id: "BUILDING" },
  { label: "planned", id: "PLANNED" },
];

const BTN_BASE =
  "text-[10px] font-mono px-3 py-1.5 rounded cursor-pointer transition-colors";
const BTN_ACTIVE = "bg-primary text-white";
const BTN_INACTIVE =
  "border border-border text-muted-foreground hover:border-primary/40 hover:text-foreground";
---

<Layout title="projects · packetcraft">
  <main class="max-w-5xl mx-auto px-6 py-12">
    <h1 class="font-bold font-mono text-3xl text-foreground mb-5">projects</h1>

    <div class="flex gap-2 mb-8" id="project-filters">
      {
        filters.map((f) => (
          <button
            data-filter={f.id}
            class:list={[BTN_BASE, f.id === "all" ? BTN_ACTIVE : BTN_INACTIVE]}
          >
            {f.label}
          </button>
        ))
      }
    </div>

    <div class="grid grid-cols-2 gap-4" id="project-grid">
      {
        projects.map((p) => (
          <a
            href={`/projects/${p.id}`}
            data-status={p.status}
            class="block bg-card border border-border rounded overflow-hidden text-left hover:border-primary/50 transition-colors group"
          >
            <Hatch class="h-24 w-full" label="screenshot" />
            <div class="p-4">
              <div class="flex items-center justify-between mb-2.5">
                <span class="font-bold font-mono text-[13px] text-foreground group-hover:text-primary transition-colors">
                  {p.name}
                </span>
                <StatusBadge status={p.status} />
              </div>
              <div class="text-[11px] font-mono text-muted-foreground leading-relaxed line-clamp-2">
                {p.description}
              </div>
              <div class="mt-3 text-[9px] font-mono text-muted-foreground">{p.meta}</div>
            </div>
          </a>
        ))
      }
    </div>
  </main>

  <script>
    const BTN_BASE =
      "text-[10px] font-mono px-3 py-1.5 rounded cursor-pointer transition-colors";
    const BTN_ACTIVE = "bg-primary text-white";
    const BTN_INACTIVE =
      "border border-border text-muted-foreground hover:border-primary/40 hover:text-foreground";

    const btns = Array.from(
      document.querySelectorAll<HTMLElement>("#project-filters [data-filter]"),
    );
    const cards = Array.from(
      document.querySelectorAll<HTMLElement>("#project-grid [data-status]"),
    );

    for (const btn of btns) {
      btn.addEventListener("click", () => {
        const f = btn.dataset.filter;
        for (const b of btns) {
          b.className = `${BTN_BASE} ${b === btn ? BTN_ACTIVE : BTN_INACTIVE}`;
        }
        for (const card of cards) {
          const show = f === "all" || card.dataset.status === f;
          card.classList.toggle("hidden", !show);
        }
      });
    }
  </script>
</Layout>
