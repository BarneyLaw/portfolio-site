---
import Layout from "../../layouts/Layout.astro";
import StatusBadge from "../../components/astro/StatusBadge.astro";
import Tag from "../../components/astro/Tag.astro";
import TerminalSnippet from "../../components/astro/TerminalSnippet.astro";
import { projects } from "../../data/projects";

export function getStaticPaths() {
  return projects.map((p) => ({ params: { id: p.id }, props: { project: p } }));
}

const { project: p } = Astro.props;
---

<Layout title={`${p.name} · packetcraft`}>
  <main class="max-w-5xl mx-auto px-6 py-12">
    <a
      href="/projects"
      class="inline-block text-[10px] font-mono text-muted-foreground hover:text-foreground transition-colors mb-5 cursor-pointer"
    >
      ← projects / {p.name}
    </a>

    <div class="flex items-center gap-3 mb-3">
      <h1 class="font-bold font-mono text-2xl text-foreground">{p.name}</h1>
      <StatusBadge status={p.status} />
    </div>

    <div class="flex gap-2 flex-wrap mb-6">
      {p.tags.map((t) => <Tag>{t}</Tag>)}
    </div>

    {/* Demo embed */}
    <div
      class="h-48 border-2 border-dashed border-primary rounded-md flex flex-col items-center justify-center gap-3 mb-8 bg-primary/5"
    >
      <div class="flex gap-1">
        {
          [0, 1, 2].map((i) => (
            <div
              class="w-2 h-2 rounded-full bg-primary"
              style={`animation: blink 1.2s steps(1) ${i * 0.4}s infinite`}
            />
          ))
        }
      </div>
      <div class="text-[10px] font-mono text-primary">demo loading…</div>
    </div>

    <div class="grid grid-cols-[1.7fr_1fr] gap-6">
      <div>
        <p class="text-[13px] font-mono text-foreground/80 leading-[1.8]">
          {p.description}
        </p>
        <div class="mt-5">
          <TerminalSnippet code={p.codeSnippet} />
        </div>
      </div>
      <div class="bg-card border border-border rounded p-4">
        <div class="text-[9px] font-mono text-muted-foreground mb-3">links</div>
        <div class="flex flex-col gap-2">
          {
            ["github ↗", "release notes ↗"].map((l) => (
              <span class="text-[11px] font-mono text-primary hover:underline cursor-pointer">
                {l}
              </span>
            ))
          }
        </div>
        <div class="mt-5 text-[9px] font-mono text-muted-foreground mb-3">meta</div>
        <div class="flex flex-col gap-1.5">
          <div class="text-[10px] font-mono text-foreground/70">
            status: <span class="text-foreground">{p.status}</span>
          </div>
          <div class="text-[10px] font-mono text-foreground/70">
            stack: <span class="text-foreground">{p.tags.join(", ")}</span>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
